/* Localizable resources for the BuildSync Assembly Wrapper add-on. */

'STR#' 32000 "Add-on Name and Description" {
/* [  1] */        "BuildSync Assembly Wrapper"
/* [  2] */        "Creates construction wrappers from selected Archicad elements."
}

'STR#' 32500 "BuildSync Menu Strings" {
/* [   ] */        "BuildSync"
/* [   ] */        "Assemblies"
/* [  1] */            "Create Joinery Wrapper from Selection^ES^EE^EI^E3^EL"
/* [  2] */            "Select Wrapper Members^ES^EE^EI^E3^EL"
/* [  3] */            "Add Selection to Wrapper^ES^EE^EI^E3^EL"
/* [  4] */            "Remove Selection from Wrapper^ES^EE^EI^E3^EL"
/* [  5] */            "Validate Selected Wrapper^ES^EE^EI^E3^EL"
/* [  6] */            "Sync Wrapper Events^ES^EE^EI^E3^EL"
/* [  7] */            "Debug Selection^ES^EE^EI^E3^EL"
/* [  8] */            "Debug Registry^ES^EE^EI^E3^EL"
/* [  9] */            "Debug BuildSync Properties^ES^EE^EI^E3^EL"
/* [ 10] */            "Manage Wrappers...^ES^EE^EI^E3^EL"
/* [ 11] */            "Place Wrapper Instance (Supported: Wall, Slab, Column, Beam, Roof, Object)^ES^EE^EI^E3^EL"
/* [ 12] */            "Place Mirrored Wrapper Instance^ES^EE^EI^E3^EL"
/* [ 13] */            "Select Wrapper Instance^ES^EE^EI^E3^EL"
/* [ 14] */            "Enter Shared Wrapper Edit Mode^ES^EE^EI^E3^EL"
/* [ 15] */            "Apply Shared Wrapper Edit^ES^EE^EI^E3^EL"
/* [ 16] */            "Cancel Shared Wrapper Edit^ES^EE^EI^E3^EL"
/* [ 17] */            "Convert Instance to Standalone Wrapper^ES^EE^EI^E3^EL"
/* [ 18] */            "Break Apart Wrapper Instance^ES^EE^EI^E3^EL"
/* [ 19] */            "Repair Wrapper Instance^ES^EE^EI^E3^EL"
}

'STR#' 32600 "BuildSync Menu Prompt Strings" {
/* [  1] */        "Create a BuildSync joinery wrapper from the selected Archicad elements."
/* [  2] */        "Select all live Archicad elements in the selected BuildSync wrapper."
/* [  3] */        "Add selected Archicad elements to the selected BuildSync wrapper."
/* [  4] */        "Remove selected Archicad elements from their BuildSync wrapper."
/* [  5] */        "Validate the selected BuildSync wrapper against live model elements."
/* [  6] */        "Send pending BuildSync wrapper events to the local listener."
/* [  7] */        "Print selected element GUIDs and element types to the Session Report."
/* [  8] */        "Print the local BuildSync wrapper registry to the Session Report."
/* [  9] */        "Print BuildSync property diagnostics for selected elements."
/* [ 10] */        "Open the BuildSync wrapper manager dialog."
/* [ 11] */        "Place a physical/countable wrapper instance. MVP supports only walls, slabs, columns, beams, roofs, and objects."
/* [ 12] */        "Place a mirrored physical/countable wrapper instance and flag it for scheduling."
/* [ 13] */        "Select all members of the wrapper instance containing the selected element."
/* [ 14] */        "Enter shared-master wrapper edit mode. Local overrides are not allowed; convert to standalone first for independent edits."
/* [ 15] */        "Apply reviewed shared-master edits to the source wrapper and every linked instance."
/* [ 16] */        "Cancel the active shared-master wrapper edit session."
/* [ 17] */        "Convert the selected instance into a standalone physical/countable wrapper."
/* [ 18] */        "Break apart the selected instance into unbound Archicad elements."
/* [ 19] */        "Repair metadata and grouping for the selected wrapper instance."
}

