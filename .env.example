# Shared runtime mode
CCP_DATA_SOURCE=demo

# When demo file mode: set to 1 so a newer demo_state.seed.json can overwrite demo_state.json on read (default off).
# CCP_REFRESH_RUNTIME_FROM_SEED=

# Shared project scope
PROJECT_ID=11111111-1111-1111-1111-111111111111
CCP_SCENARIO_ID=

# Supabase API access
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional direct Postgres connection for migration/bootstrap scripts
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Archicad adapter boundary
CCP_ARCHICAD_ADAPTER=demo
ARCHICAD_HOST=127.0.0.1
ARCHICAD_PORT=19724

# Optional web-to-desktop companion bridge
ARCHICAD_COMPANION_URL=http://127.0.0.1:19725
ARCHICAD_COMPANION_TOKEN=
